#!/bin/bash
set -eo pipefail

# Calcium Live Installer — copies the running live system to target disk
# Supports LUKS + EFI + efistub boot via dracut + efibootmgr

DIALOG=${DIALOG:-dialog}
TITLE="Calcium Linux Installer"
SWAP_SIZE="8G"

cleanup() {
  umount -R /mnt/gentoo 2>/dev/null || true
  cryptsetup close luks-root 2>/dev/null || true
}

die() {
  $DIALOG --title "$TITLE" --msgbox "$1" 10 60
  cleanup
  exit 1
}

info() {
  $DIALOG --title "$TITLE" --infobox "$1" 5 60
}

prompt_disk() {
  local disks=()
  while read -r d size; do
    [[ "$d" == loop* || "$d" == sr* ]] && continue
    disks+=("$d" "$d  ($size)")
  done < <(lsblk -dno NAME,SIZE)

  [ ${#disks[@]} -gt 0 ] || die "No disks found."

  local cmd=($DIALOG --title "$TITLE" --menu "Select target disk\nALL DATA on this disk will be DESTROYED!" 20 60 10)
  TARGET=$("${cmd[@]}" "${disks[@]}" 3>&1 1>&2 2>&3)
  [ -n "$TARGET" ] || die "No disk selected."
  TARGET="/dev/$TARGET"
}

prompt_luks() {
  $DIALOG --title "$TITLE" --yesno "Encrypt root partition with LUKS?" 8 40 && USE_LUKS=true || USE_LUKS=false
}

prompt_confirm() {
  local msg="Target: $TARGET\nLUKS: $USE_LUKS\n\nAll existing data on $TARGET will be destroyed.\nContinue?"
  $DIALOG --title "$TITLE" --yesno "$msg" 12 60 || die "Aborted."
}

# Determine partition numbering — append suffix or "pN" for nvme/mmcblk
pnum() {
  local d=$TARGET i=$1
  [[ "$TARGET" == /dev/nvme* || "$TARGET" == /dev/mmcblk* ]] && echo "${d}p${i}" || echo "${d}${i}"
}

do_partition() {
  info "Partitioning $TARGET..."
  sgdisk -Z "$TARGET"
  sgdisk -o "$TARGET"

  sgdisk -n 1:0:+512M -t 1:ef00 -c 1:"EFI System" "$TARGET"
  sgdisk -n 2:0:+${SWAP_SIZE} -t 2:8200 -c 2:"Linux Swap" "$TARGET"
  sgdisk -n 3:0:0    -t 3:8300 -c 3:"Linux Root" "$TARGET"

  PART_EFI=$(pnum 1)
  PART_SWAP=$(pnum 2)
  PART_ROOT=$(pnum 3)

  partprobe "$TARGET" 2>/dev/null || true
  sleep 2
}

do_format() {
  info "Formatting partitions..."
  mkfs.vfat -F 32 -n "EFI" "$PART_EFI"
  mkswap -L "swap" "$PART_SWAP"

  if $USE_LUKS; then
    local pass1 pass2
    while true; do
      pass1=$($DIALOG --title "$TITLE" --passwordbox "Enter LUKS passphrase:" 8 60 3>&1 1>&2 2>&3)
      pass2=$($DIALOG --title "$TITLE" --passwordbox "Confirm passphrase:" 8 60 3>&1 1>&2 2>&3)
      [ "$pass1" = "$pass2" ] && [ -n "$pass1" ] && break
      $DIALOG --title "$TITLE" --msgbox "Passwords do not match or are empty." 8 50
    done
    echo -n "$pass1" | cryptsetup luksFormat --type luks2 "$PART_ROOT" -
    echo -n "$pass1" | cryptsetup open "$PART_ROOT" luks-root -
    pass1=""; pass2=""
    LUKS_UUID=$(blkid -s UUID -o value "$PART_ROOT")
    ROOT_DEV="/dev/mapper/luks-root"
  else
    ROOT_DEV="$PART_ROOT"
  fi

  mkfs.ext4 -L "root" "$ROOT_DEV"
}

do_mount() {
  info "Mounting filesystems..."
  mkdir -p /mnt/gentoo
  mount "$ROOT_DEV" /mnt/gentoo
  mkdir -p /mnt/gentoo/boot/efi
  mount "$PART_EFI" /mnt/gentoo/boot/efi
  swapon "$PART_SWAP" 2>/dev/null || true
}

do_rsync() {
  info "Copying live system to disk (this will take a while)..."
  rsync -aAX /* /mnt/gentoo \
    --exclude=/proc \
    --exclude=/sys \
    --exclude=/dev \
    --exclude=/run \
    --exclude=/mnt \
    --exclude=/tmp \
    --exclude=/var/tmp \
    --exclude=/var/cache \
    --exclude=/usr/portage \
    --exclude=/usr/src \
    --exclude=/lost+found \
    --exclude=/swapfile \
    --exclude=/.squashfs \
    --exclude=/etc/catalyst \
    --exclude=/repo \
    2>&1 | $DIALOG --title "$TITLE" --progressbox "Copying system files..." 30 80
}

do_chroot() {
  info "Configuring installed system..."

  mount --types proc /proc /mnt/gentoo/proc
  mount --rbind /sys /mnt/gentoo/sys;  mount --make-rslave /mnt/gentoo/sys
  mount --rbind /dev /mnt/gentoo/dev;  mount --make-rslave /mnt/gentoo/dev
  mount --rbind /run /mnt/gentoo/run;  mount --make-rslave /mnt/gentoo/run

  # Export variables for the chroot script
  export ROOT_DEV PART_EFI PART_SWAP USE_LUKS LUKS_UUID TARGET

  chroot /mnt/gentoo /bin/bash <<'CHROOT'
set -e
source /etc/profile
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# --- fstab ---
cat > /etc/fstab << FSTAB
# /etc/fstab — installed by calcium-installer
FSTAB

genfstab -U / >> /etc/fstab 2>/dev/null || {
  # Manual fstab if genfstab unavailable
  ROOT_UUID=$(blkid -s UUID -o value "$ROOT_DEV")
  EFI_UUID=$(blkid -s UUID -o value "$PART_EFI")
  SWAP_UUID=$(blkid -s UUID -o value "$PART_SWAP")
  cat > /etc/fstab <<FSTAB
# /etc/fstab — installed by calcium-installer
UUID=$ROOT_UUID / ext4 defaults,noatime 0 1
UUID=$EFI_UUID /boot/efi vfat defaults 0 2
UUID=$SWAP_UUID none swap sw 0 0
FSTAB
}

# --- hostname ---
echo "calcium" > /etc/hostname
sed -i 's/127\.0\.0\.1\s.*/127.0.0.1\tcalcium.localdomain\tcalcium/' /etc/hosts

# --- root password ---
echo
echo "=== Set root password for the installed system ==="
passwd

# --- kernel + initramfs ---
emerge --quiet --getbinpkg --noreplace sys-kernel/gentoo-kernel-bin sys-kernel/dracut

KVER=$(ls /lib/modules/ | head -1)

DRACUT_ARGS="--force --hostonly --kver $KVER"
if $USE_LUKS; then
  DRACUT_ARGS="$DRACUT_ARGS -a dm -a rd.luks"
fi
dracut $DRACUT_ARGS /boot/initramfs.img

# Copy kernel for EFI stub
cp "/boot/vmlinuz-$KVER" /boot/vmlinuz.efi

# --- efibootmgr ---
ROOT_UUID=$(blkid -s UUID -o value "$ROOT_DEV")
if $USE_LUKS; then
  CMDLINE="root=UUID=$ROOT_UUID rd.luks.uuid=$LUKS_UUID rd.luks.name=$LUKS_UUID=root quiet"
else
  CMDLINE="root=UUID=$ROOT_UUID quiet"
fi

# Determine disk for efibootmgr (strip partition number)
DEST_DISK="$TARGET"
# efibootmgr takes the raw disk, partition 1 is the ESP
# We use partition 1 for EFI
efibootmgr --create --disk "$DEST_DISK" --part 1 --label "Calcium Linux" \
  --loader /vmlinuz.efi --unicode "$CMDLINE"

CHROOT
}

do_finish() {
  cleanup
  if $DIALOG --title "$TITLE" --yesno "Installation complete!\n\nReboot now?" 10 50; then
    reboot
  fi
}

# --- Main ---
[ "$EUID" -eq 0 ] || die "Please run as root."

which $DIALOG &>/dev/null || die "$DIALOG not found. Install dev-util/dialog."

prompt_disk
prompt_luks
prompt_confirm
do_partition
do_format
do_mount
do_rsync
do_chroot
do_finish
