#: prefs.js:34
msgid "About Medialine"
msgstr "О Medialine"

#: prefs.js:58 helpers/indicator.js:71
msgid "Medialine"
msgstr "Medialine"

#: prefs.js:62
msgid "Shows currently playing media in the top bar in a minimal elegant way."
msgstr ""
"Отображает текущий медиаконтент в верхней панели минимально и элегантно."

#: prefs.js:73
msgid "Donate"
msgstr "Поддержать"

#: prefs.js:74
msgid "GitHub"
msgstr "GitHub"

#: prefs.js:75
msgid "Twitter"
msgstr "Twitter"

#: prefs.js:76
msgid "Email"
msgstr "Эл. почта"

#: prefs.js:83
msgid "Top Bar"
msgstr "Верхняя панель"

#: prefs.js:89
msgid "Panel placement"
msgstr "Расположение на панели"

#: prefs.js:90
msgid "Where the indicator appears in the top bar."
msgstr "Где индикатор отображается на верхней панели."

#: prefs.js:94
msgid "Panel section"
msgstr "Секция панели"

#: prefs.js:95
msgid "Which area of the top bar to place the indicator"
msgstr "В какой области верхней панели разместить индикатор"

#: prefs.js:96
msgid "Left"
msgstr "Слева"

#: prefs.js:96
msgid "Center"
msgstr "По центру"

#: prefs.js:96
msgid "Right"
msgstr "Справа"

#: prefs.js:98
msgid "Position index"
msgstr "Индекс позиции"

#: prefs.js:98
msgid "Order within the panel section (0 is first)"
msgstr "Порядок в секции панели (0 — первый)"

#: prefs.js:101
msgid "Icon"
msgstr "Значок"

#: prefs.js:102
msgid ""
"How Medialine represents the currently playing media in the panel and popup."
msgstr ""
"Как Medialine отображает текущий медиаконтент на панели и во всплывающем "
"окне."

#: prefs.js:106
msgid "Icon source"
msgstr "Источник значка"

#: prefs.js:107
msgid "Album art, app icon, playback status, or a custom image"
msgstr ""
"Обложка альбома, значок приложения, статус воспроизведения или "
"пользовательское изображение"

#: prefs.js:109
msgid "App icon"
msgstr "Значок приложения"

#: prefs.js:110
msgid "Album art"
msgstr "Обложка альбома"

#: prefs.js:111
msgid "Playing status"
msgstr "Статус воспроизведения"

#: prefs.js:112 prefs.js:147
msgid "Custom image"
msgstr "Пользовательское изображение"

#: prefs.js:117
msgid "Icon size"
msgstr "Размер значка"

#: prefs.js:117
msgid "Size in pixels"
msgstr "Размер в пикселях"

#: prefs.js:119
msgid "Icon spacing"
msgstr "Отступ значка"

#: prefs.js:119
msgid "Space between the icon and text in pixels"
msgstr "Расстояние между значком и текстом в пикселях"

#: prefs.js:130
msgid "Label"
msgstr "Надпись"

#: prefs.js:131
msgid "Control what text appears next to the icon in the panel."
msgstr "Управляет текстом рядом со значком на панели."

#: prefs.js:135
msgid "Show title"
msgstr "Показывать название"

#: prefs.js:136
msgid "Show artist"
msgstr "Показывать исполнителя"

#: prefs.js:137
msgid "Show album"
msgstr "Показывать альбом"

#: prefs.js:138
msgid "Separator"
msgstr "Разделитель"

#: prefs.js:140
msgid "Max text width"
msgstr "Максимальная ширина текста"

#: prefs.js:140
msgid "Maximum label width in pixels (0 for unlimited)"
msgstr "Максимальная ширина надписи в пикселях (0 — без ограничений)"

#: prefs.js:148
msgid "Pick an image to use when the icon source is set to Custom image."
msgstr ""
"Выберите изображение, когда источник значка — «Пользовательское изображение»."

#: prefs.js:155
msgid "Image file"
msgstr "Файл изображения"

#: prefs.js:156 prefs.js:201
msgid "No file selected"
msgstr "Файл не выбран"

#: prefs.js:193
msgid "Choose image"
msgstr "Выбрать изображение"

#: prefs.js:219
msgid "Images"
msgstr "Изображения"

#: prefs.js:227
msgid "Select custom image"
msgstr "Выбрать пользовательское изображение"

#: prefs.js:261
msgid "Popup"
msgstr "Всплывающее окно"

#: prefs.js:266
msgid "Colors"
msgstr "Цвета"

#: prefs.js:267
msgid "Customize the popup color scheme"
msgstr "Настроить цветовую схему всплывающего окна"

#: prefs.js:272
msgid "Primary color"
msgstr "Основной цвет"

#: prefs.js:272
msgid "Color for text and controls"
msgstr "Цвет текста и элементов управления"

#: prefs.js:275
msgid "Secondary color"
msgstr "Дополнительный цвет"

#: prefs.js:275
msgid "Color for backgrounds and accents"
msgstr "Цвет фона и акцентов"

#: prefs.js:278
msgid "Background color"
msgstr "Цвет фона"

#: prefs.js:278
msgid ""
"Background color for the popup (will also be used as fallback if dynamic "
"background is enabled)."
msgstr ""
"Цвет фона всплывающего окна (также используется как запасной, если включён "
"динамический фон)."

#: prefs.js:282
msgid "Dynamic background"
msgstr "Динамический фон"

#: prefs.js:283
msgid "Use the dominant color from album art as background"
msgstr "Использовать доминирующий цвет обложки альбома как фон"

#: prefs.js:287
msgid "Background intensity"
msgstr "Интенсивность фона"

#: prefs.js:288
msgid "How bright or dark the dynamic background appears"
msgstr "Насколько светлым или тёмным выглядит динамический фон"

#: prefs.js:302
msgid "Display"
msgstr "Отображение"

#: prefs.js:303
msgid "Control what the popup shows and how it behaves."
msgstr "Управляет тем, что отображает всплывающее окно и как оно ведёт себя."

#: prefs.js:308
msgid "Music visualizer"
msgstr "Музыкальный визуализатор"

#: prefs.js:309
msgid "Animated bars next to the track info for some eye candy."
msgstr "Анимированные столбики рядом с информацией о треке для красоты."

#: prefs.js:312
msgid "App icon on album art"
msgstr "Значок приложения на обложке альбома"

#: prefs.js:313
msgid "Overlay the playing app’s icon on the bottom right of the album art"
msgstr ""
"Накладывать значок воспроизводящего приложения в правом нижнем углу обложки "
"альбома"

#: prefs.js:316
msgid "Expand compact layout on"
msgstr "Раскрывать компактный режим при"

#: prefs.js:316
msgid "How multi-source rows expand when several apps play"
msgstr ""
"Как раскрываются строки с несколькими источниками, когда воспроизводят "
"несколько приложений"

#: prefs.js:317
msgid "Off"
msgstr "Выкл."

#: prefs.js:317
msgid "Hover"
msgstr "Наведении"

#: prefs.js:317
msgid "Click"
msgstr "Нажатии"

#: prefs.js:324
msgid "Behaviour"
msgstr "Поведение"

#: prefs.js:329
msgid "Click actions"
msgstr "Действия при нажатии"

#: prefs.js:330
msgid "What happens when you click the media bar indicator"
msgstr "Что происходит при нажатии на индикатор медиапанели"

#: prefs.js:335 prefs.js:361
msgid "Nothing"
msgstr "Ничего"

#: prefs.js:335 prefs.js:361
msgid "Open popup"
msgstr "Открыть всплывающее окно"

#: prefs.js:335 prefs.js:361
msgid "Play / Pause"
msgstr "Воспроизведение / Пауза"

#: prefs.js:335 prefs.js:361
msgid "Open settings"
msgstr "Открыть настройки"

#: prefs.js:336 prefs.js:362
msgid "Next track"
msgstr "Следующий трек"

#: prefs.js:336 prefs.js:362
msgid "Previous track"
msgstr "Предыдущий трек"

#: prefs.js:336 prefs.js:363
msgid "Raise player"
msgstr "Показать плеер"

#: prefs.js:342
msgid "Left click"
msgstr "Левая кнопка"

#: prefs.js:342
msgid "Action when left-clicking the indicator"
msgstr "Действие при щелчке левой кнопкой по индикатору"

#: prefs.js:343
msgid "Middle click"
msgstr "Средняя кнопка"

#: prefs.js:343
msgid "Action when middle-clicking the indicator"
msgstr "Действие при щелчке средней кнопкой по индикатору"

#: prefs.js:344
msgid "Right click"
msgstr "Правая кнопка"

#: prefs.js:344
msgid "Action when right-clicking the indicator"
msgstr "Действие при щелчке правой кнопкой по индикатору"

#: prefs.js:355
msgid "Scroll actions"
msgstr "Действия при прокрутке"

#: prefs.js:356
msgid "What happens when you scroll over the media bar indicator"
msgstr "Что происходит при прокрутке над индикатором медиапанели"

#: prefs.js:363
msgid "Volume up"
msgstr "Увеличить громкость"

#: prefs.js:363
msgid "Volume down"
msgstr "Уменьшить громкость"

#: prefs.js:367
msgid "Scroll up"
msgstr "Прокрутка вверх"

#: prefs.js:367
msgid "Action when scrolling up over the indicator"
msgstr "Действие при прокрутке вверх над индикатором"

#: prefs.js:368
msgid "Scroll down"
msgstr "Прокрутка вниз"

#: prefs.js:368
msgid "Action when scrolling down over the indicator"
msgstr "Действие при прокрутке вниз над индикатором"

#: prefs.js:374
msgid "Notifications"
msgstr "Уведомления"

#: prefs.js:375
msgid "Manage visibility of GNOME’s built-in media notifications."
msgstr "Управляет видимостью встроенных медиауведомлений GNOME."

#: prefs.js:379
msgid "Hide default notification"
msgstr "Скрыть стандартное уведомление"

#: prefs.js:380
msgid "Remove GNOME’s media notification while the panel indicator is shown"
msgstr "Скрывать медиауведомление GNOME, пока отображается индикатор панели"

#: prefs.js:383
msgid "Compatibility"
msgstr "Совместимость"

#: prefs.js:384
msgid "Workarounds for specific apps and environments."
msgstr "Решения для конкретных приложений и сред."

#: prefs.js:388
msgid "Enhanced PWA support"
msgstr "Расширенная поддержка PWA"

#: prefs.js:389
msgid ""
"Use advanced detection to find the active PWA window for the correct icon. "
"Might have unintended consequences of displaying the wrong icon."
msgstr ""
"Использовать расширенное определение для нахождения активного окна PWA. "
"Может привести к отображению неверного значка."

#: prefs.js:392
msgid "Album art cache"
msgstr "Кэш обложек альбомов"

#: prefs.js:393
msgid "Downloaded cover art (e.g. from Spotify) is cached on disk."
msgstr ""
"Загруженные обложки (например, из Spotify) кэшируются на диске."

#: prefs.js:397
msgid "Cache size limit"
msgstr "Ограничение размера кэша"

#: prefs.js:397
msgid "Maximum disk space in megabytes"
msgstr "Максимальное место на диске в мегабайтах"

#: prefs.js:413
msgid "Choose a color"
msgstr "Выбрать цвет"

#: prefs.js:434
msgid "Reset to default"
msgstr "Сбросить до стандартных"

