#: prefs.js:34
msgid "About Medialine"
msgstr "Acerca de Medialine"

#: prefs.js:58 helpers/indicator.js:71
msgid "Medialine"
msgstr "Medialine"

#: prefs.js:62
msgid "Shows currently playing media in the top bar in a minimal elegant way."
msgstr ""
"Muestra el medio en reproducción en la barra superior de forma mínima y "
"elegante."

#: prefs.js:73
msgid "Donate"
msgstr "Donar"

#: prefs.js:74
msgid "GitHub"
msgstr "GitHub"

#: prefs.js:75
msgid "Twitter"
msgstr "Twitter"

#: prefs.js:76
msgid "Email"
msgstr "Correo electrónico"

#: prefs.js:83
msgid "Top Bar"
msgstr "Barra superior"

#: prefs.js:89
msgid "Panel placement"
msgstr "Posición en el panel"

#: prefs.js:90
msgid "Where the indicator appears in the top bar."
msgstr "Dónde aparece el indicador en la barra superior."

#: prefs.js:94
msgid "Panel section"
msgstr "Sección del panel"

#: prefs.js:95
msgid "Which area of the top bar to place the indicator"
msgstr "En qué área de la barra superior colocar el indicador"

#: prefs.js:96
msgid "Left"
msgstr "Izquierda"

#: prefs.js:96
msgid "Center"
msgstr "Centro"

#: prefs.js:96
msgid "Right"
msgstr "Derecha"

#: prefs.js:98
msgid "Position index"
msgstr "Índice de posición"

#: prefs.js:98
msgid "Order within the panel section (0 is first)"
msgstr "Orden dentro de la sección del panel (0 es el primero)"

#: prefs.js:101
msgid "Icon"
msgstr "Icono"

#: prefs.js:102
msgid ""
"How Medialine represents the currently playing media in the panel and popup."
msgstr ""
"Cómo Medialine representa el medio en reproducción en el panel y en la "
"ventana emergente."

#: prefs.js:106
msgid "Icon source"
msgstr "Fuente del icono"

#: prefs.js:107
msgid "Album art, app icon, playback status, or a custom image"
msgstr ""
"Portada del álbum, icono de la app, estado de reproducción o una imagen "
"personalizada"

#: prefs.js:109
msgid "App icon"
msgstr "Icono de la app"

#: prefs.js:110
msgid "Album art"
msgstr "Portada del álbum"

#: prefs.js:111
msgid "Playing status"
msgstr "Estado de reproducción"

#: prefs.js:112 prefs.js:147
msgid "Custom image"
msgstr "Imagen personalizada"

#: prefs.js:117
msgid "Icon size"
msgstr "Tamaño del icono"

#: prefs.js:117
msgid "Size in pixels"
msgstr "Tamaño en píxeles"

#: prefs.js:119
msgid "Icon spacing"
msgstr "Espaciado del icono"

#: prefs.js:119
msgid "Space between the icon and text in pixels"
msgstr "Espacio entre el icono y el texto en píxeles"

#: prefs.js:130
msgid "Label"
msgstr "Etiqueta"

#: prefs.js:131
msgid "Control what text appears next to the icon in the panel."
msgstr "Controla qué texto aparece junto al icono en el panel."

#: prefs.js:135
msgid "Show title"
msgstr "Mostrar título"

#: prefs.js:136
msgid "Show artist"
msgstr "Mostrar artista"

#: prefs.js:137
msgid "Show album"
msgstr "Mostrar álbum"

#: prefs.js:138
msgid "Separator"
msgstr "Separador"

#: prefs.js:140
msgid "Max text width"
msgstr "Ancho máximo del texto"

#: prefs.js:140
msgid "Maximum label width in pixels (0 for unlimited)"
msgstr "Ancho máximo de la etiqueta en píxeles (0 para ilimitado)"

#: prefs.js:148
msgid "Pick an image to use when the icon source is set to Custom image."
msgstr ""
"Elige una imagen cuando la fuente del icono sea «Imagen personalizada»."

#: prefs.js:155
msgid "Image file"
msgstr "Archivo de imagen"

#: prefs.js:156 prefs.js:201
msgid "No file selected"
msgstr "Ningún archivo seleccionado"

#: prefs.js:193
msgid "Choose image"
msgstr "Elegir imagen"

#: prefs.js:219
msgid "Images"
msgstr "Imágenes"

#: prefs.js:227
msgid "Select custom image"
msgstr "Seleccionar imagen personalizada"

#: prefs.js:261
msgid "Popup"
msgstr "Ventana emergente"

#: prefs.js:266
msgid "Colors"
msgstr "Colores"

#: prefs.js:267
msgid "Customize the popup color scheme"
msgstr "Personalizar el esquema de colores de la ventana emergente"

#: prefs.js:272
msgid "Primary color"
msgstr "Color primario"

#: prefs.js:272
msgid "Color for text and controls"
msgstr "Color para texto y controles"

#: prefs.js:275
msgid "Secondary color"
msgstr "Color secundario"

#: prefs.js:275
msgid "Color for backgrounds and accents"
msgstr "Color para fondos y acentos"

#: prefs.js:278
msgid "Background color"
msgstr "Color de fondo"

#: prefs.js:278
msgid ""
"Background color for the popup (will also be used as fallback if dynamic "
"background is enabled)."
msgstr ""
"Color de fondo de la ventana emergente (también se usará como alternativa si "
"el fondo dinámico está activado)."

#: prefs.js:282
msgid "Dynamic background"
msgstr "Fondo dinámico"

#: prefs.js:283
msgid "Use the dominant color from album art as background"
msgstr "Usar el color dominante de la portada del álbum como fondo"

#: prefs.js:287
msgid "Background intensity"
msgstr "Intensidad del fondo"

#: prefs.js:288
msgid "How bright or dark the dynamic background appears"
msgstr "Qué tan brillante u oscuro aparece el fondo dinámico"

#: prefs.js:302
msgid "Display"
msgstr "Visualización"

#: prefs.js:303
msgid "Control what the popup shows and how it behaves."
msgstr "Controla qué muestra la ventana emergente y cómo se comporta."

#: prefs.js:308
msgid "Music visualizer"
msgstr "Visualizador de música"

#: prefs.js:309
msgid "Animated bars next to the track info for some eye candy."
msgstr "Barras animadas junto a la información de la pista para dar un toque visual."

#: prefs.js:312
msgid "App icon on album art"
msgstr "Icono de la app sobre la portada del álbum"

#: prefs.js:313
msgid "Overlay the playing app’s icon on the bottom right of the album art"
msgstr ""
"Superponer el icono de la app en reproducción en la esquina inferior derecha "
"de la portada del álbum"

#: prefs.js:316
msgid "Expand compact layout on"
msgstr "Expandir diseño compacto al"

#: prefs.js:316
msgid "How multi-source rows expand when several apps play"
msgstr "Cómo se expanden las filas de múltiples fuentes cuando varias apps reproducen"

#: prefs.js:317
msgid "Off"
msgstr "Desactivado"

#: prefs.js:317
msgid "Hover"
msgstr "Pasar el ratón"

#: prefs.js:317
msgid "Click"
msgstr "Hacer clic"

#: prefs.js:324
msgid "Behaviour"
msgstr "Comportamiento"

#: prefs.js:329
msgid "Click actions"
msgstr "Acciones de clic"

#: prefs.js:330
msgid "What happens when you click the media bar indicator"
msgstr "Qué ocurre al hacer clic en el indicador de la barra de medios"

#: prefs.js:335 prefs.js:361
msgid "Nothing"
msgstr "Nada"

#: prefs.js:335 prefs.js:361
msgid "Open popup"
msgstr "Abrir ventana emergente"

#: prefs.js:335 prefs.js:361
msgid "Play / Pause"
msgstr "Reproducir / Pausar"

#: prefs.js:335 prefs.js:361
msgid "Open settings"
msgstr "Abrir ajustes"

#: prefs.js:336 prefs.js:362
msgid "Next track"
msgstr "Pista siguiente"

#: prefs.js:336 prefs.js:362
msgid "Previous track"
msgstr "Pista anterior"

#: prefs.js:336 prefs.js:363
msgid "Raise player"
msgstr "Mostrar reproductor"

#: prefs.js:342
msgid "Left click"
msgstr "Clic izquierdo"

#: prefs.js:342
msgid "Action when left-clicking the indicator"
msgstr "Acción al hacer clic izquierdo en el indicador"

#: prefs.js:343
msgid "Middle click"
msgstr "Clic central"

#: prefs.js:343
msgid "Action when middle-clicking the indicator"
msgstr "Acción al hacer clic central en el indicador"

#: prefs.js:344
msgid "Right click"
msgstr "Clic derecho"

#: prefs.js:344
msgid "Action when right-clicking the indicator"
msgstr "Acción al hacer clic derecho en el indicador"

#: prefs.js:355
msgid "Scroll actions"
msgstr "Acciones de desplazamiento"

#: prefs.js:356
msgid "What happens when you scroll over the media bar indicator"
msgstr "Qué ocurre al desplazarse sobre el indicador de la barra de medios"

#: prefs.js:363
msgid "Volume up"
msgstr "Subir volumen"

#: prefs.js:363
msgid "Volume down"
msgstr "Bajar volumen"

#: prefs.js:367
msgid "Scroll up"
msgstr "Desplazar hacia arriba"

#: prefs.js:367
msgid "Action when scrolling up over the indicator"
msgstr "Acción al desplazarse hacia arriba sobre el indicador"

#: prefs.js:368
msgid "Scroll down"
msgstr "Desplazar hacia abajo"

#: prefs.js:368
msgid "Action when scrolling down over the indicator"
msgstr "Acción al desplazarse hacia abajo sobre el indicador"

#: prefs.js:374
msgid "Notifications"
msgstr "Notificaciones"

#: prefs.js:375
msgid "Manage visibility of GNOME’s built-in media notifications."
msgstr ""
"Gestiona la visibilidad de las notificaciones de medios integradas en GNOME."

#: prefs.js:379
msgid "Hide default notification"
msgstr "Ocultar notificación predeterminada"

#: prefs.js:380
msgid "Remove GNOME’s media notification while the panel indicator is shown"
msgstr ""
"Eliminar la notificación de medios de GNOME mientras se muestra el indicador "
"del panel"

#: prefs.js:383
msgid "Compatibility"
msgstr "Compatibilidad"

#: prefs.js:384
msgid "Workarounds for specific apps and environments."
msgstr "Soluciones para aplicaciones y entornos específicos."

#: prefs.js:388
msgid "Enhanced PWA support"
msgstr "Compatibilidad mejorada con PWA"

#: prefs.js:389
msgid ""
"Use advanced detection to find the active PWA window for the correct icon. "
"Might have unintended consequences of displaying the wrong icon."
msgstr ""
"Usar detección avanzada para encontrar la ventana PWA activa y mostrar el "
"icono correcto. Puede tener consecuencias no deseadas al mostrar el icono "
"incorrecto."

#: prefs.js:392
msgid "Album art cache"
msgstr "Caché de portadas de álbum"

#: prefs.js:393
msgid "Downloaded cover art (e.g. from Spotify) is cached on disk."
msgstr ""
"Las portadas descargadas (p. ej. de Spotify) se almacenan en caché en el "
"disco."

#: prefs.js:397
msgid "Cache size limit"
msgstr "Límite de tamaño de la caché"

#: prefs.js:397
msgid "Maximum disk space in megabytes"
msgstr "Espacio máximo en disco en megabytes"

#: prefs.js:413
msgid "Choose a color"
msgstr "Elegir un color"

#: prefs.js:434
msgid "Reset to default"
msgstr "Restablecer predeterminado"

#: helpers/indicator.js:437 helpers/expandableMediaRow.js:142
msgid "Unknown"
msgstr "Desconocido"

