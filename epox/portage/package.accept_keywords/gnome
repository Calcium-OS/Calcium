# GNOME 49/50 ~amd64 keywords for LiveCD
# Base GNOME components (full stack for 49+)
gnome-base/* ~amd64
gnome-extra/* ~amd64
gnome-extra/gnome-shell-extensions ~amd64
x11-wm/* ~amd64
x11-themes/* ~amd64

# GNOME 50 specific packages (injected from overlay)
>=gnome-base/gnome-shell-50 ~amd64
>=x11-wm/mutter-50 ~amd64
>=gnome-base/gnome-session-50 ~amd64
>=gnome-base/gnome-settings-daemon-50 ~amd64
>=gnome-base/gnome-control-center-50 ~amd64
>=gnome-base/nautilus-50 ~amd64
>=gnome-base/gsettings-desktop-schemas-50 ~amd64
>=gnome-base/gdm-50 ~amd64

# GNOME shell integration and extensions
gui-libs/* ~amd64
gui-apps/* ~amd64

# Dependencies that may need keywords for newer GNOME
media-libs/gsound ~amd64
media-libs/graphene ~amd64
media-plugins/* ~amd64

# GNOME 50 dependency: image loading library
media-libs/glycin ~amd64
media-libs/glycin-loaders ~amd64

# GNOME 50 dependency: tracker/localsearch (needed by nautilus)
app-misc/tinysparql ~amd64
app-misc/localsearch ~amd64

# Core libraries for GNOME 49/50
app-accessibility/at-spi2-core ~amd64
dev-libs/glib ~amd64
dev-libs/gobject-introspection ~amd64
dev-libs/libxml2 ~amd64
dev-libs/json-glib ~amd64
net-libs/libsoup ~amd64
net-libs/glib-networking ~amd64

# Display and windowing
x11-libs/* ~amd64
x11-libs/gtk+ ~amd64
x11-libs/pango ~amd64
x11-libs/cairo ~amd64
x11-base/xorg-server ~amd64
media-libs/mesa ~amd64
media-libs/libepoxy ~amd64
media-libs/fontconfig ~amd64

# Dist-kernel (always want latest)
sys-kernel/gentoo-kernel-bin ~amd64
sys-kernel/linux-firmware ~amd64

# Audio
media-sound/* ~amd64
media-libs/pulseaudio ~amd64
media-libs/pipewire ~amd64
